# Hermass W14 内测环境变量模板
# 复制为 .env 后填入你的真实凭证

# 必填: 飞书开发者后台 → 事件订阅 → Verification Token
LARK_VERIFICATION_TOKEN=your_token_here

# 可选: 飞书 App Secret（用于消息签名验证，增强安全性）
LARK_APP_SECRET=your_secret_here

# ── SMTP 邮件推送 ──────────────────────────────────
# 用于日报 / 报告邮件推送（当前使用 QQ 邮箱 SMTP）
# 获取方式：QQ 邮箱 → 设置 → 账户 → 开启 SMTP → 生成授权码
export HERMASS_SMTP_USER=your_qq_email@qq.com
export HERMASS_SMTP_PASS=your_smtp_auth_code
export HERMASS_REPORT_TO=recipient1@qq.com,recipient2@qq.com

# ── AI 模型 ────────────────────────────────────────
# DeepSeek API（用于 Agently 多 Agent 编排与观象问答）
export HERMASS_DEEPSEEK_API_KEY=your_deepseek_api_key
export HERMASS_DEEPSEEK_MODEL=deepseek-chat
export HERMASS_DEEPSEEK_BASE_URL=https://api.deepseek.com
